<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.45"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:strokeColor="#C9A227"
            app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_parchment_panel">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/profile_avatar"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/avatar_1"
                            android:contentDescription="Avatar"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/profile_username"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/main_font_family"
                                tools:text="PlayerOne" />

                            <TextView
                                android:id="@+id/profile_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="#7A0F0F"
                                android:textSize="16sp"
                                android:textStyle="italic"
                                android:fontFamily="@font/main_font_family"
                                tools:text="Apprentice" />

                            <LinearLayout
                                android:id="@+id/profile_stats_container"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="BasePP: "
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/main_font_family" />

                                <TextView
                                    android:id="@+id/profile_pp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/main_font_family"
                                    tools:text="120" />

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginStart="16dp"
                                    android:src="@drawable/coins"
                                    android:contentDescription="Coins" />

                                <TextView
                                    android:id="@+id/profile_coins"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/main_font_family"
                                    tools:text="250" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Badges: "
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/main_font_family" />

                                <TextView
                                    android:id="@+id/profile_badges"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/main_font_family"
                                    tools:text="120" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/profile_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#7A0F0F"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:fontFamily="@font/main_font_family"
                            tools:text="Lv. 5" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <ProgressBar
                            android:id="@+id/profile_xp_bar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            android:progressDrawable="@drawable/progress_xp_bar"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="30" />

                        <TextView
                            android:id="@+id/profile_xp_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/black"
                            android:fontFamily="@font/main_font_family"
                            tools:text="30/100" />

                        <!-- QR and Buttons section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <!-- QR Code (Left) -->
                            <LinearLayout
                                android:id="@+id/profile_qr_container"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Scan to add friend"
                                    android:textColor="@color/black"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/main_font_family"
                                    android:layout_marginBottom="8dp" />

                                <ImageView
                                    android:id="@+id/profile_qr_image"
                                    android:layout_width="100dp"
                                    android:layout_height="100dp"
                                    android:contentDescription="QR Code"
                                    tools:src="@drawable/ic_crown" />
                            </LinearLayout>

                            <!-- Buttons (Right) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_change_password"
                                    android:layout_width="match_parent"
                                    android:layout_height="52dp"
                                    android:text="Change Password"
                                    android:textAllCaps="false"
                                    android:textSize="14sp"
                                    android:textColor="#C9A227"
                                    android:fontFamily="@font/main_font_family"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_button_fantasy"
                                    app:backgroundTint="@null"
                                    app:rippleColor="#33C9A227"
                                    app:cornerRadius="12dp"
                                    android:layout_marginBottom="8dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_statistics"
                                    android:layout_width="match_parent"
                                    android:layout_height="52dp"
                                    android:text="Statistics"
                                    android:textAllCaps="false"
                                    android:textSize="14sp"
                                    android:textColor="#C9A227"
                                    android:fontFamily="@font/main_font_family"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_button_fantasy"
                                    app:backgroundTint="@null"
                                    app:rippleColor="#33C9A227"
                                    app:cornerRadius="12dp"/>

                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Inventory Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/inventory_card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.275"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:strokeColor="#C9A227"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_parchment_panel">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inventory"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/main_font_family"
                    android:layout_marginBottom="12dp" />

                <ListView
                    android:id="@+id/inventory_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Equipped Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.275"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:strokeColor="#C9A227"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_parchment_panel">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equipped"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/main_font_family"
                    android:layout_marginBottom="12dp" />

                <ListView
                    android:id="@+id/equipped_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</FrameLayout>