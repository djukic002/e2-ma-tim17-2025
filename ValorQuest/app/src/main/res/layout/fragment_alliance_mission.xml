<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <TextView
        android:id="@+id/missionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alliance mission"
        android:textColor="#C9A227"
        android:textSize="40sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMission"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Create Mission"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/missionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        app:layout_constraintWidth_percent="0.5" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/missionContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnMission"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvMissionDates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01 Oct 2025 - 10 Oct 2025"
            android:textColor="#C9A227"
            android:textSize="24sp"
            android:fontFamily="@font/main_font_family"
            android:textStyle="bold"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvBossName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Warchief Orgrim Doomhammer"
            android:textColor="#8B1E1E"
            android:textSize="24sp"
            android:fontFamily="@font/main_font_family"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvMissionDates"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RelativeLayout
            android:id="@+id/hpBarContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvBossName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ProgressBar
                android:id="@+id/progressBossHp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:max="100"
                android:progress="100"
                android:progressTint="#CC3333"
                android:backgroundTint="#600000"
                android:scaleY="2.5" />

            <TextView
                android:id="@+id/tvBossHpText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500 / 1000"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/main_font_family"
                android:layout_centerInParent="true" />

        </RelativeLayout>

        <ScrollView
            android:id="@+id/scrollMissionContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/hpBarContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:id="@+id/missionDetailsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tvRewardsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Possible Rewards"
                    android:textColor="#C9A227"
                    android:textSize="30sp"
                    android:fontFamily="@font/main_font_family"
                    android:textStyle="bold"
                    android:shadowColor="#99000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="12dp"
                    android:layout_gravity="center_horizontal" />

                <LinearLayout
                    android:id="@+id/rewardsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Random Equipment"
                            android:textColor="#8B1E1E"
                            android:textSize="20sp"
                            android:fontFamily="@font/main_font_family"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <ImageView
                            android:id="@+id/imgRewardEquipment"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/a3"
                            android:contentDescription="Random Equipment" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/goldReward"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200 Gold"
                            android:textColor="#8B1E1E"
                            android:textSize="20sp"
                            android:fontFamily="@font/main_font_family"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <ImageView
                            android:id="@+id/imgRewardGold"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/coins"
                            android:contentDescription="200 Gold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Random Potion"
                            android:textColor="#8B1E1E"
                            android:textSize="20sp"
                            android:fontFamily="@font/main_font_family"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <ImageView
                            android:id="@+id/imgRewardPotion"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/p2"
                            android:contentDescription="Random Potion" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvNoMission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No mission is active"
        android:textColor="#8B1E1E"
        android:textSize="24sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnMission"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
