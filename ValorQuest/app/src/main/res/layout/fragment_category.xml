<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Categories"
        android:textColor="#C9A227"
        android:textSize="40sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manage Your Quest Categories"
        android:textColor="#8B1E1E"
        android:textSize="24sp"
        android:fontFamily="@font/main_font_family"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Add Category Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_go_add_category"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Add Category"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:rippleColor="#33C9A227"
        app:cornerRadius="14dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Placeholder for future category list -->
    <TextView
        android:id="@+id/tvPlaceholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Categories Fragment - Coming Soon"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#8B1E1E"
        android:fontFamily="@font/main_font_family"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/btn_go_add_category"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>