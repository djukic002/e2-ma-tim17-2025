<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- Video takes the middle space -->
    <VideoView
        android:id="@+id/bossVideo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/equipmentBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.85"
        android:background="@drawable/bg_bordered_box"/>

    <!-- Overlay container for stats & button -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/bossVideo"
        app:layout_constraintBottom_toBottomOf="@id/bossVideo"
        app:layout_constraintStart_toStartOf="@id/bossVideo"
        app:layout_constraintEnd_toEndOf="@id/bossVideo"
        android:elevation="10dp">

        <!-- ************ HP BAR (TOP OVERLAY - Bar remains) ************ -->
        <RelativeLayout
            android:id="@+id/hpBarContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:elevation="1dp">

            <!-- HP Progress Bar (Red) -->
            <ProgressBar
                android:id="@+id/pbHpBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:max="100"
                android:progress="100"
                android:progressTint="#CC3333"
                android:backgroundTint="#600000"
                android:scaleY="2.5" />

            <!-- HP Label and Value centered over the bar -->
            <TextView
                android:id="@+id/tvHpValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HP: 200/200"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/main_font_family"
                android:layout_centerInParent="true" />

        </RelativeLayout>
        <!-- ************ END HP BAR ************ -->

        <!-- Row at the bottom of video: Attack counter | Button | Hit chance -->
        <LinearLayout
            android:id="@+id/bottomHud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Attack Counter -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attacks:"
                    android:textColor="#8B1E1E"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/main_font_family"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvAttackCountValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="#8B1E1E"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/main_font_family"/>
            </LinearLayout>

            <!-- Attack Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBoss"
                android:layout_height="56dp"
                android:layout_width="wrap_content"
                android:text="Attack !"
                android:textAllCaps="false"
                android:textSize="20sp"
                android:textColor="#C9A227"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:background="@drawable/bg_button_fantasy"
                app:backgroundTint="@null"
                app:cornerRadius="14dp"
                android:layout_marginHorizontal="8dp"/>

            <!-- Hit Chance -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hit %:"
                    android:textColor="#8B1E1E"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/main_font_family"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvHitChanceValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="67"
                    android:textColor="#8B1E1E"
                    android:textStyle="bold"
                    android:textSize="28sp"
                    android:fontFamily="@font/main_font_family"/>
            </LinearLayout>

        </LinearLayout>
        <!-- ************ END bottomHud ************ -->


        <!-- ************ PP TEXT/LABEL (ABOVE bottomHud - Reverted to text) ************ -->
        <LinearLayout
            android:id="@+id/ppTextViewContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintBottom_toTopOf="@id/bottomHud"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PP:"
                android:textColor="#66B2FF"
                android:textSize="24sp"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tvPpValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:textColor="#66B2FF"
                android:textSize="28sp"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"/>
        </LinearLayout>
        <!-- ************ END PP TEXT/LABEL ************ -->

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Equipment bar -->
    <HorizontalScrollView
        android:id="@+id/equipmentBar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:scrollbars="none"
        android:padding="8dp"
        android:layout_marginBottom="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_equipment_bar">

        <LinearLayout
            android:id="@+id/equipmentContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <!-- No ImageViews here, they will be added by UserItemArrayAdapter -->
        </LinearLayout>

    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
