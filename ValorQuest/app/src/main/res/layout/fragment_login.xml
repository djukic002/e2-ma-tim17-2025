<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".ui.auth.LoginFragment">

    <View
        android:id="@+id/scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/login_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="100dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="10dp"
        app:cardCornerRadius="20dp"
        app:strokeColor="#C9A227"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="22dp"
            android:background="@drawable/bg_parchment_panel">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter the Realm"
                android:textColor="#8B1E1E"
                android:textSize="28sp"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Only the worthy may proceed"
                android:textColor="#7A0F0F"
                android:textSize="14sp"
                android:fontFamily="@font/main_font_family" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/email_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:hint="Email"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#C9A227"
                app:boxStrokeWidth="2dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="#8B1E1E"
                app:hintTextColor="#8B1E1E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#111111"
                    android:textColorHint="#7A0F0F"
                    android:fontFamily="@font/main_font_family"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress"
                    android:importantForAutofill="yes"
                    android:background="@android:color/transparent" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/password_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Secret Sigil"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="#C9A227"
                app:boxStrokeWidth="2dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#8B1E1E"
                app:endIconMode="password_toggle"
                app:endIconTint="#8B1E1E"
                app:hintTextColor="#8B1E1E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#111111"
                    android:textColorHint="#7A0F0F"
                    android:fontFamily="@font/main_font_family"
                    android:inputType="textPassword"
                    android:background="@android:color/transparent" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/forgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Forgot your sigil?"
                android:textColor="#8B1E1E"
                android:textSize="12sp"
                android:fontFamily="@font/main_font_family" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:text="Enter"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textColor="#C9A227"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:background="@drawable/bg_button_fantasy"
                app:backgroundTint="@null"
                app:rippleColor="#33C9A227"
                app:cornerRadius="14dp"
                app:iconGravity="textStart" />

            <LinearLayout
                android:id="@+id/register_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/no_account_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New to the world?"
                    android:textColor="#111111"
                    android:textSize="13sp"
                    android:fontFamily="@font/main_font_family" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_register"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Register"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="#7A0F0F"
                    android:fontFamily="@font/main_font_family"
                    app:rippleColor="#198B1E1E" />
            </LinearLayout>

            <TextView
                android:id="@+id/footer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="Protected by the Ancient Oath"
                android:textColor="#7A0F0F"
                android:textSize="11sp"
                android:fontFamily="@font/main_font_family" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>