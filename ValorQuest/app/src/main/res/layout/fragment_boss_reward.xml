<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- Chest image takes center screen -->
    <ImageView
        android:id="@+id/ivChest"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/chest_closed"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClaimChest"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:text="Claim"
        android:textAllCaps="false"
        android:textColor="#C9A227"
        android:textSize="20sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toBottomOf="@id/ivChest"
        app:layout_constraintStart_toStartOf="@id/ivChest"
        app:layout_constraintEnd_toEndOf="@id/ivChest"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:elevation="10dp"/>

    <!-- Open button on top of chest, z-indexed -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenChest"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:text="Open"
        android:textAllCaps="false"
        android:textColor="#C9A227"
        android:textSize="20sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toBottomOf="@id/ivChest"
        app:layout_constraintStart_toStartOf="@id/ivChest"
        app:layout_constraintEnd_toEndOf="@id/ivChest"
        android:layout_marginBottom="16dp"
        android:elevation="10dp" />

</androidx.constraintlayout.widget.ConstraintLayout>