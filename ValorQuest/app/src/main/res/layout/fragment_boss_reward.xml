<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#B3000000">

    <!-- Rewards container -->
    <LinearLayout
        android:id="@+id/rewardsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="15dp"
        app:layout_constraintBottom_toTopOf="@id/ivChest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gold Column -->
        <LinearLayout
            android:id="@+id/goldColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivGold"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/coins"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvGoldAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textColor="#C9A227"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Equipment Column -->
        <LinearLayout
            android:id="@+id/equipmentColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="1"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivEquipment"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/w1"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvEquipmentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="200dp"
                android:textSize="20sp"
                android:textColor="#C9A227"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true"
                android:scrollHorizontally="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Chest -->

    <!-- Open button below chest -->
    <ImageView
        android:id="@+id/ivChest"
        android:layout_width="0dp"
        android:layout_height="350dp"
        android:elevation="5dp"
        android:scaleType="fitCenter"
        android:src="@drawable/chest_closed"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.56"
        app:layout_constraintWidth_percent="0.8" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenChest"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:text="Open"
        android:textAllCaps="false"
        android:textColor="#C9A227"
        android:textSize="20sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/ivChest"
        app:layout_constraintStart_toStartOf="@id/ivChest"
        app:layout_constraintEnd_toEndOf="@id/ivChest"
        android:layout_marginTop="10dp"
        android:elevation="10dp" />

    <!-- Claim button (hidden initially, same position as open button) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClaimChest"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:text="Claim"
        android:textAllCaps="false"
        android:textColor="#C9A227"
        android:textSize="20sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/ivChest"
        app:layout_constraintStart_toStartOf="@id/ivChest"
        app:layout_constraintEnd_toEndOf="@id/ivChest"
        android:layout_marginTop="10dp"
        android:elevation="10dp"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
