<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    
    <!-- Circle background -->
    <solid android:color="#F4E4BC" />
    
    <!-- Golden border -->
    <stroke
        android:width="2dp"
        android:color="#C9A227" />
    
    <!-- Size -->
    <size
        android:width="40dp"
        android:height="40dp" />

</shape>
