<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ValorQuest"
        android:textColor="#C9A227"
        android:textSize="40sp"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Your Path"
        android:textColor="#8B1E1E"
        android:textSize="24sp"
        android:fontFamily="@font/main_font_family"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buttons vertically stacked, half width -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnQuests"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Quests"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        android:layout_marginTop="40dp"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShop"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Shop"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        android:layout_marginTop="32dp"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintTop_toBottomOf="@id/btnQuests"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProfile"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Profile"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        android:layout_marginTop="32dp"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintTop_toBottomOf="@id/btnShop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCategories"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Categories"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        android:layout_marginTop="32dp"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintTop_toBottomOf="@id/btnProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBoss"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Boss fight"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        android:layout_marginTop="32dp"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintTop_toBottomOf="@id/btnSocial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSocial"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="Social"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#C9A227"
        android:fontFamily="@font/main_font_family"
        android:textStyle="bold"
        android:background="@drawable/bg_button_fantasy"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:iconGravity="textStart"
        android:layout_marginTop="32dp"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintTop_toBottomOf="@id/btnCategories"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>