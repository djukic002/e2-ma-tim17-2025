<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="end">

        <!-- Message container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

        <!-- Username -->
        <TextView
            android:id="@+id/message_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textSize="12sp"
            android:textColor="#8B1E1E"
            android:textStyle="bold"
            android:fontFamily="@font/main_font_family"
            android:layout_marginBottom="4dp"
            android:layout_marginEnd="48dp" />

        <!-- Avatar and message bubble row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

             <!-- Message bubble -->
             <com.google.android.material.card.MaterialCardView
                 android:layout_width="170dp"
                 android:layout_height="wrap_content"
                 android:layout_gravity="end"
                 app:cardCornerRadius="16dp"
                 app:strokeColor="#C9A227"
                 app:strokeWidth="1dp">

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:orientation="vertical"
                     android:padding="12dp"
                     android:background="@drawable/bg_message_right">

                    <!-- Message text -->
                    <TextView
                        android:id="@+id/message_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Message text here"
                        android:textSize="14sp"
                        android:textColor="#2C1810"
                        android:fontFamily="@font/main_font_family"
                        android:lineSpacingExtra="2dp" />

                    <!-- Timestamp -->
                    <TextView
                        android:id="@+id/message_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:text="12:34"
                        android:textSize="10sp"
                        android:textColor="#8B1E1E"
                        android:fontFamily="@font/main_font_family" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

             <!-- Avatar -->
             <ImageView
                 android:id="@+id/message_avatar"
                 android:layout_width="40dp"
                 android:layout_height="40dp"
                 android:layout_gravity="bottom"
                 android:layout_marginStart="8dp"
                 android:src="@drawable/avatar_1"
                 android:scaleType="centerCrop"
                 android:background="@drawable/bg_avatar_circle"
                 android:clipToOutline="true" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
