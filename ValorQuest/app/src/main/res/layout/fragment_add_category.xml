<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardUseCompatPadding="true"
        app:cardElevation="10dp"
        app:cardCornerRadius="20dp"
        app:strokeColor="#C9A227"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp"
            android:background="@drawable/bg_parchment_panel">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Category"
                android:textColor="#8B1E1E"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/main_font_family" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_category_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Category name"
                app:boxBackgroundMode="none"
                app:hintTextColor="#8B1E1E">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_category_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#111111"
                    android:textColorHint="#7A0F0F"
                    android:fontFamily="@font/main_font_family"
                    android:background="@android:color/transparent" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Color input + live preview -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/color_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_color_hex"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Color hex (#RRGGBB or #AARRGGBB)"
                    app:boxBackgroundMode="none"
                    app:hintTextColor="#8B1E1E"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/color_preview"
                    android:layout_marginEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_color_hex"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="#FF9800"
                        android:textColor="#111111"
                        android:textColorHint="#7A0F0F"
                        android:fontFamily="@font/main_font_family"
                        android:background="@android:color/transparent" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/color_preview"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#C9A227"
                    app:strokeWidth="2dp"
                    app:cardBackgroundColor="#FF9800"
                    app:layout_constraintTop_toTopOf="@id/til_color_hex"
                    app:layout_constraintBottom_toBottomOf="@id/til_color_hex"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_category"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:text="Add"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textColor="#C9A227"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:background="@drawable/bg_button_fantasy"
                app:backgroundTint="@null"
                app:rippleColor="#33C9A227"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>