<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".ui.auth.AvatarSelectionFragment">

    <View
        android:id="@+id/scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/avatar_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="100dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="10dp"
        app:cardCornerRadius="20dp"
        app:strokeColor="#C9A227"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="22dp"
            android:background="@drawable/bg_parchment_panel">

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Your Avatar"
                android:textColor="#8B1E1E"
                android:textSize="28sp"
                android:fontFamily="@font/main_font_family"
                android:textStyle="bold"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Select your champion's appearance"
                android:textColor="#7A0F0F"
                android:textSize="14sp"
                android:fontFamily="@font/main_font_family" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="18dp"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Avatar 1 -->
                    <LinearLayout
                        android:id="@+id/avatar_1_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:background="@drawable/avatar_selection_background"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/avatar_1_image"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/avatar_1"
                            android:contentDescription="Avatar 1"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/avatar_1_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Warrior"
                                android:textColor="#8B1E1E"
                                android:textSize="16sp"
                                android:fontFamily="@font/main_font_family"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/avatar_1_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A mighty warrior with unbreakable spirit"
                                android:textColor="#7A0F0F"
                                android:textSize="12sp"
                                android:fontFamily="@font/main_font_family"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/avatar_1_check"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check"
                            android:contentDescription="Selected"
                            android:visibility="gone"
                            android:tint="#C9A227" />
                    </LinearLayout>

                    <!-- Avatar 2 -->
                    <LinearLayout
                        android:id="@+id/avatar_2_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:background="@drawable/avatar_selection_background"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/avatar_2_image"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/avatar_2"
                            android:contentDescription="Avatar 2"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/avatar_2_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mage"
                                android:textColor="#8B1E1E"
                                android:textSize="16sp"
                                android:fontFamily="@font/main_font_family"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/avatar_2_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A wise mage with ancient knowledge"
                                android:textColor="#7A0F0F"
                                android:textSize="12sp"
                                android:fontFamily="@font/main_font_family"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/avatar_2_check"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check"
                            android:contentDescription="Selected"
                            android:visibility="gone"
                            android:tint="#C9A227" />
                    </LinearLayout>

                    <!-- Avatar 3 -->
                    <LinearLayout
                        android:id="@+id/avatar_3_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:background="@drawable/avatar_selection_background"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/avatar_3_image"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/avatar_3"
                            android:contentDescription="Avatar 3"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/avatar_3_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Archer"
                                android:textColor="#8B1E1E"
                                android:textSize="16sp"
                                android:fontFamily="@font/main_font_family"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/avatar_3_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A skilled archer with deadly precision"
                                android:textColor="#7A0F0F"
                                android:textSize="12sp"
                                android:fontFamily="@font/main_font_family"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/avatar_3_check"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check"
                            android:contentDescription="Selected"
                            android:visibility="gone"
                            android:tint="#C9A227" />
                    </LinearLayout>

                    <!-- Avatar 4 -->
                    <LinearLayout
                        android:id="@+id/avatar_4_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:background="@drawable/avatar_selection_background"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/avatar_4_image"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/avatar_4"
                            android:contentDescription="Avatar 4"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/avatar_4_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rogue"
                                android:textColor="#8B1E1E"
                                android:textSize="16sp"
                                android:fontFamily="@font/main_font_family"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/avatar_4_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A stealthy rogue with quick reflexes"
                                android:textColor="#7A0F0F"
                                android:textSize="12sp"
                                android:fontFamily="@font/main_font_family"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/avatar_4_check"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check"
                            android:contentDescription="Selected"
                            android:visibility="gone"
                            android:tint="#C9A227" />
                    </LinearLayout>

                    <!-- Avatar 5 -->
                    <LinearLayout
                        android:id="@+id/avatar_5_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:background="@drawable/avatar_selection_background"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/avatar_5_image"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/avatar_5"
                            android:contentDescription="Avatar 5"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/avatar_5_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Paladin"
                                android:textColor="#8B1E1E"
                                android:textSize="16sp"
                                android:fontFamily="@font/main_font_family"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/avatar_5_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A holy paladin with divine protection"
                                android:textColor="#7A0F0F"
                                android:textSize="12sp"
                                android:fontFamily="@font/main_font_family"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/avatar_5_check"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check"
                            android:contentDescription="Selected"
                            android:visibility="gone"
                            android:tint="#C9A227" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Back"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="#8B1E1E"
                    android:fontFamily="@font/main_font_family"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_outline"
                    app:backgroundTint="@null"
                    app:rippleColor="#198B1E1E"
                    app:cornerRadius="14dp"
                    app:strokeColor="#8B1E1E"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_complete_registration"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Complete"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="#C9A227"
                    android:fontFamily="@font/main_font_family"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_fantasy"
                    app:backgroundTint="@null"
                    app:rippleColor="#33C9A227"
                    app:cornerRadius="14dp" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>