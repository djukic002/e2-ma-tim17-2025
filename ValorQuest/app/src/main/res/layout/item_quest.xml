<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="10dp"
    android:background="@drawable/horizontal_scroll"
    android:gravity="center_vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/viewCategoryColor"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="10dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#C9A227"
        app:strokeWidth="0dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvQuestName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quest name"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#8B1E1E"
            android:fontFamily="@font/main_font_family" />

        <TextView
            android:id="@+id/tvQuestDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textSize="18sp"
            android:textColor="#111111"
            android:fontFamily="@font/main_font_family" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="20dp">

        <TextView
            android:id="@+id/tvQuestImportance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Importance"
            android:textSize="18sp"
            android:textColor="#111111"
            android:fontFamily="@font/main_font_family" />

        <TextView
            android:id="@+id/tvQuestStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="18sp"
            android:textColor="#111111"
            android:fontFamily="@font/main_font_family" />
    </LinearLayout>
</LinearLayout>
